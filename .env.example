# SmartLeave AI — Frontend environment variables

# Base URL of your Express + MySQL backend (e.g. https://api.smartleave.com/api)
VITE_API_BASE_URL=https://smartleave-backend.onrender.com/api

# Set to "false" to talk to the real backend at VITE_API_BASE_URL.
# Leave as "true" (default) to use the in-browser mock backend with seeded data.
VITE_USE_MOCK_API=false

